# This clang-format configuration is compatible with clang-format 15 to 18
BasedOnStyle: WebKit
Language: Cpp
Standard: c++20
ColumnLimit: 100

# Switch/case settings
IndentCaseLabels: true

# Alignment settings
AlignConsecutiveMacros: true

# Comment reflow settings
CommentPragmas: '^\s*NOLINT'

# Force braces after control statements (if, else, for, do, and while)
InsertBraces: true

# Disable short blocks on single line except for switch cases
AllowShortEnumsOnASingleLine: false
AllowShortFunctionsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: true

# Concept/require clause settings
IndentRequires: true

# Template settings
AlwaysBreakTemplateDeclarations: true
SpaceAfterTemplateKeyword: false

# Namespace settings
CompactNamespaces: true
FixNamespaceComments: true
NamespaceIndentation: None

# Parameter splitting
# If parameters/arguments do not fit in a single line, break them one by line using
# ContinuationIndentWidth as indentation.
AlignAfterOpenBracket: AlwaysBreak
BinPackArguments: false
BinPackParameters: false
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false
# Occasionally clang-format breaks lines between return type and function name. Disabling this.
PenaltyReturnTypeOnItsOwnLine: 1000
# It also breaks before assignment operator even when the operand is a function call. Disabling this.
PenaltyBreakAssignment: 1000
